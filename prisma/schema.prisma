generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users / Auth ────────────────────────────────────────────────────────────

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(ADMIN)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  articles  Article[]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

// ─── Categories ──────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  color       String?
  icon        String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  articles    Article[]
}

// ─── Articles / News ─────────────────────────────────────────────────────────

model Article {
  id              String        @id @default(uuid())
  title           String
  slug            String        @unique
  excerpt         String?
  content         String        @db.Text
  featuredImage   String?
  author          User          @relation(fields: [authorId], references: [id])
  authorId        String
  category        Category      @relation(fields: [categoryId], references: [id])
  categoryId      String
  status          ArticleStatus @default(DRAFT)
  isBreaking      Boolean       @default(false)
  isTrending      Boolean       @default(false)
  isFeatured      Boolean       @default(false)
  viewCount       Int           @default(0)
  readTime        Int           @default(5)
  tags            String[]
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime?
  scheduledAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([slug])
  @@index([categoryId])
  @@index([status])
  @@index([publishedAt])
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

// ─── Tournaments ─────────────────────────────────────────────────────────────

model Tournament {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logo      String?
  country   String?
  sport     String   @default("Football")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  matches   Match[]
}

// ─── Teams ───────────────────────────────────────────────────────────────────

model Team {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logo        String?
  country     String?
  sport       String   @default("Football")
  createdAt   DateTime @default(now())
  homeMatches Match[]  @relation("HomeTeam")
  awayMatches Match[]  @relation("AwayTeam")
}

// ─── Matches ─────────────────────────────────────────────────────────────────

model Match {
  id              String          @id @default(uuid())
  title           String
  slug            String          @unique
  homeTeam        Team            @relation("HomeTeam", fields: [homeTeamId], references: [id])
  homeTeamId      String
  awayTeam        Team            @relation("AwayTeam", fields: [awayTeamId], references: [id])
  awayTeamId      String
  tournament      Tournament      @relation(fields: [tournamentId], references: [id])
  tournamentId    String
  matchTime       DateTime
  status          MatchStatus     @default(UPCOMING)
  homeScore       Int?
  awayScore       Int?
  minute          Int?
  banner          String?
  isFeatured      Boolean         @default(false)
  isActive        Boolean         @default(true)
  destinationType DestinationType @default(INTERNAL)
  externalUrl     String?
  metaTitle       String?
  metaDescription String?
  viewCount       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  channels        Channel[]

  @@index([status])
  @@index([matchTime])
  @@index([slug])
}

enum MatchStatus {
  UPCOMING
  LIVE
  HT
  FINISHED
  POSTPONED
  CANCELLED
}

enum DestinationType {
  INTERNAL
  EXTERNAL
}

// ─── Channels ────────────────────────────────────────────────────────────────

model Channel {
  id             String   @id @default(uuid())
  match          Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId        String
  name           String
  language       String   @default("English")
  logo           String?
  thumbnail      String?
  destinationUrl String
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Advertisements ──────────────────────────────────────────────────────────

model Advertisement {
  id        String    @id @default(uuid())
  name      String
  slot      AdSlot
  network   AdNetwork @default(ADSENSE)
  code      String    @db.Text
  isActive  Boolean   @default(true)
  position  Int       @default(0)
  page      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum AdSlot {
  HEADER_BANNER
  LEFT_SIDEBAR_TOP
  LEFT_SIDEBAR_BOTTOM
  RIGHT_SIDEBAR_TOP
  RIGHT_SIDEBAR_BOTTOM
  IN_ARTICLE_1
  IN_ARTICLE_2
  BETWEEN_CONTENT
  FOOTER_BANNER
  STICKY_MOBILE
  MATCH_PAGE_TOP
  MATCH_PAGE_BOTTOM
  NATIVE_RECOMMENDATION
}

enum AdNetwork {
  ADSENSE
  EZOIC
  MEDIA_NET
  CUSTOM
}

// ─── Analytics ───────────────────────────────────────────────────────────────

model PageView {
  id        String   @id @default(uuid())
  path      String
  referrer  String?
  userAgent String?
  ip        String?
  country   String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
}

model SiteStats {
  id             String   @id @default(uuid())
  date           DateTime @unique @db.Date
  totalViews     Int      @default(0)
  uniqueVisitors Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Settings ────────────────────────────────────────────────────────────────

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  group     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
